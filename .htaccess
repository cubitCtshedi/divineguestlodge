# ============================================================
#  Divine Guest Lodge — Apache config
# ============================================================

# ------------------------------------------------------------
#  Security headers
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set X-XSS-Protection "0"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=(), payment=(), interest-cohort=()"

  Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.clarity.ms https://*.clarity.ms; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data: https://*.clarity.ms; frame-src https://www.google.com; connect-src 'self' https://www.clarity.ms https://*.clarity.ms; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; upgrade-insecure-requests"

  # HSTS — only enable once you're confident HTTPS is permanent on this domain
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ------------------------------------------------------------
#  Force HTTPS + retire WordPress endpoints
# ------------------------------------------------------------
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Force HTTPS
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # WordPress endpoints — return 410 Gone so search engines drop them
  RewriteRule ^wp-admin($|/)        - [R=410,L]
  RewriteRule ^wp-login\.php$       - [R=410,L]
  RewriteRule ^wp-includes($|/)     - [R=410,L]
  RewriteRule ^wp-content($|/)      - [R=410,L]
  RewriteRule ^wp-json($|/)         - [R=410,L]
  RewriteRule ^xmlrpc\.php$         - [R=410,L]
  RewriteRule ^wp-cron\.php$        - [R=410,L]
  RewriteRule ^wp-trackback\.php$   - [R=410,L]

  # Sensitive WP files — hard 403, must never be served
  RewriteRule ^wp-config(-sample)?\.php$ - [F,L]
  RewriteRule ^\.env$                    - [F,L]
</IfModule>

# Block any leftover PHP from being executed at the root level.
# (Comment this out if you ever add PHP back to this site.)
<FilesMatch "\.(php|phtml|php[3-8])$">
  Require all denied
</FilesMatch>

# But keep index.html winning at the root
DirectoryIndex index.html

# ------------------------------------------------------------
#  Compression — Brotli first (smaller), gzip as fallback
# ------------------------------------------------------------
<IfModule mod_brotli.c>
  AddOutputFilterByType BROTLI_COMPRESS text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/manifest+json image/svg+xml
</IfModule>
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml application/manifest+json image/svg+xml
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm|css|js|json|xml|svg|webmanifest)$">
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>

# ------------------------------------------------------------
#  Browser caching — TTLs (mod_expires)
# ------------------------------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 month"
  ExpiresByType text/html                 "access plus 1 hour"
  ExpiresByType text/css                  "access plus 1 year"
  ExpiresByType application/javascript    "access plus 1 year"
  ExpiresByType image/jpeg                "access plus 1 year"
  ExpiresByType image/png                 "access plus 1 year"
  ExpiresByType image/webp                "access plus 1 year"
  ExpiresByType image/avif                "access plus 1 year"
  ExpiresByType image/svg+xml             "access plus 1 year"
  ExpiresByType image/x-icon              "access plus 1 year"
  ExpiresByType font/woff                 "access plus 1 year"
  ExpiresByType font/woff2                "access plus 1 year"
  ExpiresByType application/manifest+json "access plus 1 week"
  ExpiresByType text/xml                  "access plus 1 day"
  ExpiresByType application/xml           "access plus 1 day"
</IfModule>

# ------------------------------------------------------------
#  Cache-Control — immutable for static assets, revalidate for HTML/SW
# ------------------------------------------------------------
<IfModule mod_headers.c>
  # Long-lived, content-addressable-ish assets
  <FilesMatch "\.(jpg|jpeg|png|webp|avif|gif|svg|ico|woff|woff2|ttf|otf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML must always revalidate so site updates are picked up quickly
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>

  # Service worker must NEVER be cached by browsers — required for updates
  <FilesMatch "^sw\.js$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
    Header set Service-Worker-Allowed "/"
  </FilesMatch>

  # XML files (sitemap, etc.) — short cache so search engines see updates
  <FilesMatch "\.(xml|txt)$">
    Header set Cache-Control "public, max-age=86400"
  </FilesMatch>

  # Manifest
  <FilesMatch "\.webmanifest$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
</IfModule>

# ------------------------------------------------------------
#  Connection keep-alive
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header set Connection keep-alive
</IfModule>

# ------------------------------------------------------------
#  ETag — disable in favour of Cache-Control + Last-Modified
# ------------------------------------------------------------
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None

